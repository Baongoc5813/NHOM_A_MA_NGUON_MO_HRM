<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="email_template_interview_invitation" model="mail.template">
            <field name="name">Interview - Invitation</field>
            <field name="model_id" ref="calendar.model_calendar_event"/>
            <field name="subject">Interview Invitation: {{ object.name }}</field>
            <field name="body_html"><![CDATA[
<div style="font-family:Arial,sans-serif;max-width:600px;margin:0 auto;color:#333">
  <div style="background:#1f6fad;padding:20px;border-radius:8px 8px 0 0">
    <h2 style="color:#fff;margin:0">Interview Invitation</h2>
  </div>
  <div style="border:1px solid #ddd;border-top:none;padding:24px;border-radius:0 0 8px 8px">
    <p>Dear Candidate / Interviewer,</p>
    <p>You are invited to an interview. Details below:</p>
    <table style="width:100%;border-collapse:collapse;margin:16px 0">
      <tr style="background:#f5f5f5">
        <td style="padding:10px;font-weight:bold;width:40%">Event</td>
        <td style="padding:10px">{{ object.name }}</td>
      </tr>
      <tr>
        <td style="padding:10px;font-weight:bold">Date</td>
        <td style="padding:10px">{{ object.start }}</td>
      </tr>
      <tr style="background:#f5f5f5">
        <td style="padding:10px;font-weight:bold">Type</td>
        <td style="padding:10px">{{ object.interview_type or 'N/A' }}</td>
      </tr>
    </table>
    <p>Please confirm your attendance by replying to this email.</p>
  </div>
</div>
            ]]></field>
            <field name="auto_delete" eval="True"/>
        </record>
    </data>
</odoo>
