<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- res.groups.privilege: nhóm category để hiện trong UI user -->
        <record id="groups_privilege_interview" model="res.groups.privilege">
            <field name="name">Interview Scheduling</field>
            <field name="category_id" ref="base.module_category_human_resources_recruitment"/>
            <field name="sequence">10</field>
        </record>

        <!-- Group: Interviewer -->
        <record id="group_interviewer" model="res.groups">
            <field name="name">Interviewer</field>
            <field name="privilege_id" ref="groups_privilege_interview"/>
            <field name="sequence">10</field>
        </record>

        <!-- Group: HR Interview Officer (implies Interviewer, gán admin) -->
        <record id="group_hr_interview_officer" model="res.groups">
            <field name="name">HR Interview Officer</field>
            <field name="privilege_id" ref="groups_privilege_interview"/>
            <field name="sequence">20</field>
            <field name="implied_ids" eval="[(4, ref('group_interviewer'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
        </record>

    </data>
</odoo>
