<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══ Form ═══════════════════════════════════════════════════ -->
    <record id="view_hr_interview_feedback_form" model="ir.ui.view">
        <field name="name">hr.interview.feedback.form</field>
        <field name="model">hr.interview.feedback</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit_feedback"
                            string="Submit Feedback"
                            type="object"
                            class="btn-primary"
                            invisible="state == 'submitted'"/>
                    <button name="action_reset_to_draft"
                            string="Reset to Draft"
                            type="object"
                            groups="interview_scheduling.group_hr_interview_officer"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted"/>
                </header>
                <sheet>
                    <group>
                        <group string="Interview Details">
                            <field name="applicant_id" readonly="1"/>
                            <field name="job_id" readonly="1"/>
                            <field name="calendar_event_id"/>
                            <field name="interview_date" readonly="1"/>
                            <field name="interview_round"/>
                            <field name="interview_type"/>
                            <field name="submitted_on" readonly="1"
                                   invisible="state == 'draft'"/>
                        </group>
                        <group string="Interviewer and Attendance">
                            <field name="interviewer_id"
                                   groups="interview_scheduling.group_hr_interview_officer"/>
                            <field name="interviewer_id"
                                   groups="!interview_scheduling.group_hr_interview_officer"
                                   readonly="1"/>
                            <field name="attendance_status"
                                   groups="interview_scheduling.group_hr_interview_officer"/>
                            <field name="attendance_status"
                                   groups="!interview_scheduling.group_hr_interview_officer"
                                   readonly="1"/>
                        </group>
                    </group>
                    <group string="Scores (0 to 10)">
                        <group>
                            <field name="score_communication"/>
                            <field name="score_technical"/>
                        </group>
                        <group>
                            <field name="score_problem_solving"/>
                            <field name="score_culture_fit"/>
                        </group>
                    </group>
                    <group>
                        <field name="score_overall" readonly="1"/>
                        <field name="recommendation"/>
                    </group>
                    <group string="Strengths">
                        <field name="strengths" nolabel="1"/>
                    </group>
                    <group string="Areas for Improvement">
                        <field name="weaknesses" nolabel="1"/>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ══ List ═══════════════════════════════════════════════════ -->
    <record id="view_hr_interview_feedback_list" model="ir.ui.view">
        <field name="name">hr.interview.feedback.list</field>
        <field name="model">hr.interview.feedback</field>
        <field name="arch" type="xml">
            <list decoration-success="recommendation == 'pass' and state == 'submitted'"
                  decoration-danger="recommendation == 'fail' and state == 'submitted'"
                  decoration-warning="recommendation == 'consider' and state == 'submitted'"
                  decoration-muted="state == 'draft'">
                <field name="applicant_id"/>
                <field name="job_id"/>
                <field name="interview_round"/>
                <field name="interview_date"/>
                <field name="interviewer_id"/>
                <field name="attendance_status" widget="badge"
                       decoration-success="attendance_status == 'showed_up'"
                       decoration-danger="attendance_status == 'no_show'"
                       decoration-warning="attendance_status == 'rescheduled'"/>
                <field name="score_overall"/>
                <field name="recommendation" widget="badge"
                       decoration-success="recommendation == 'pass'"
                       decoration-danger="recommendation == 'fail'"
                       decoration-warning="recommendation == 'consider'"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'submitted'"
                       decoration-info="state == 'draft'"/>
            </list>
        </field>
    </record>

    <!-- ══ Action ═════════════════════════════════════════════════ -->
    <record id="action_hr_interview_feedback" model="ir.actions.act_window">
        <field name="name">Interview Feedbacks</field>
        <field name="res_model">hr.interview.feedback</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No feedbacks yet</p>
            <p>Feedback forms are created automatically when an interview is scheduled.</p>
        </field>
    </record>

</odoo>
