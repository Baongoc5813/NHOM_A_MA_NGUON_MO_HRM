<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_applicant_portal_button" model="ir.ui.view">
        <field name="name">hr.applicant.portal.button</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_recruitment.hr_applicant_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_send_portal_link"
                        string="Gửi Link Portal"
                        type="object"
                        class="btn-primary"/>
            </xpath>
        </field>
    </record>
</odoo>
