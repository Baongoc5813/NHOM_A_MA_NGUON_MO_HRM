<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Override header brand to use our custom NovaSync logo -->
    <template id="candidate_portal_branding_header" inherit_id="website.layout" name="Candidate Portal Branding Header" priority="60">
        <xpath expr="//t[@t-call='website.placeholder_header_brand']" position="replace">
            <a href="/" class="navbar-brand logo">
                <img t-att-src="'/candidate_portal/static/src/img/novasync-logo.svg'" alt="NovaSync" style="height:40px; width:auto;"/>
            </a>
        </xpath>
    </template>

    <!-- Override footer copyright to show NovaSync -->
    <template id="candidate_portal_branding_footer" inherit_id="website.footer_copyright_company_name" name="Candidate Portal Branding Footer">
        <xpath expr="//footer//span[hasclass('o_footer_copyright_name')]" position="replace">
            <span class="o_footer_copyright_name me-2 small">Copyright &amp;copy; NovaSync</span>
        </xpath>
    </template>
</odoo>
