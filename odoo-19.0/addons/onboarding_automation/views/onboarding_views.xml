<odoo>
    <record id="view_onboarding_request_list" model="ir.ui.view">
        <field name="name">hr.onboarding.request.list</field>
        <field name="model">hr.onboarding.request</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'draft'" decoration-warning="state == 'in_progress'" decoration-success="state == 'done'">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="onboarding_date"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'in_progress'" decoration-success="state == 'done'"/>
            </list>
        </field>
    </record>

    <record id="view_onboarding_request_kanban" model="ir.ui.view">
        <field name="name">hr.onboarding.request.kanban</field>
        <field name="model">hr.onboarding.request</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" quick_create="false">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="onboarding_date"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click fw-bold text-primary mb-1">
                            <field name="name"/>
                        </div>
                        <div class="text-muted small">
                            Employee: <field name="employee_id"/>
                        </div>
                        <div class="oe_kanban_footer mt-2 d-flex justify-content-between align-items-center">
                            <span class="text-muted small"><field name="onboarding_date"/></span>
                            <field name="user_id" widget="many2one_avatar_user"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_onboarding_request_form" model="ir.ui.view">
        <field name="name">hr.onboarding.request.form</field>
        <field name="model">hr.onboarding.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_start_onboarding"
                            type="object"
                            string="Start Onboarding"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,done"/>
                </header>
                
                <sheet>
                    <widget name="web_ribbon" title="Completed" bg_color="text-bg-success" invisible="state != 'done'"/>
                    
                    <div class="oe_title">
                        <label for="name" string="Onboarding Request"/>
                        <h1>
                            <field name="name" placeholder="e.g., Onboarding - John Doe"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="employee_id" options="{'no_create': True}"/>
                            <field name="employee_email"/> 
                        </group>
                        <group>
                            <field name="onboarding_date"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Tasks" name="tasks">
                            <field name="task_ids">
                                <list editable="bottom" decoration-success="state == 'done'" decoration-warning="state == 'todo'">
                                    <field name="name"/>
                                    <field name="assigned_department" widget="selection"/>
                                    <field name="user_id" widget="many2one_avatar_user"/>
                                    <field name="deadline"/>
                                    <field name="state" widget="selection" readonly="0"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_onboarding_request" model="ir.actions.act_window">
        <field name="name">Onboarding</field>
        <field name="res_model">hr.onboarding.request</field>
        <field name="view_mode">kanban,list,form</field>
    </record>
    
    <record id="action_onboarding_request_view_kanban" model="ir.actions.act_window.view">
        <field name="sequence" eval="10"/>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="view_onboarding_request_kanban"/>
        <field name="act_window_id" ref="action_onboarding_request"/>
    </record>

    <record id="action_onboarding_request_view_list" model="ir.actions.act_window.view">
        <field name="sequence" eval="20"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_onboarding_request_list"/>
        <field name="act_window_id" ref="action_onboarding_request"/>
    </record>

    <record id="action_onboarding_request_view_form" model="ir.actions.act_window.view">
        <field name="sequence" eval="30"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_onboarding_request_form"/>
        <field name="act_window_id" ref="action_onboarding_request"/>
    </record>

    <menuitem
        id="menu_onboarding_root"
        name="Onboarding"
        sequence="10"
    />

    <menuitem
        id="menu_onboarding_requests"
        name="Onboarding Request"
        parent="menu_onboarding_root"
        action="action_onboarding_request"
        sequence="10"
    />
</odoo>