<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_suggest_assignee_wizard_form" model="ir.ui.view">
        <field name="name">project.suggest.assignee.wizard.form</field>
        <field name="model">project.suggest.assignee.wizard</field>
        <field name="arch" type="xml">
            <form string="Suggest Assignees">
                <sheet>
                    <group>
                        <field name="task_id" readonly="1"/>
                        <field name="employee_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Apply" type="object" name="action_apply" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
