<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="rule_workload_metric_manager_all" model="ir.rule">
            <field name="name">Workload Metric: project managers can see all</field>
            <field name="model_id" ref="model_project_workload_metric"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('project.group_project_manager'))]"/>
        </record>
        <record id="rule_workload_metric_user_own" model="ir.rule">
            <field name="name">Workload Metric: employees see own metrics</field>
            <field name="model_id" ref="model_project_workload_metric"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('project.group_project_user'))]"/>
        </record>
        <record id="rule_assignment_rule_manager_all" model="ir.rule">
            <field name="name">Assignment Rule: project managers can manage all</field>
            <field name="model_id" ref="model_project_assignment_rule"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('project.group_project_manager'))]"/>
        </record>
    </data>
</odoo>
