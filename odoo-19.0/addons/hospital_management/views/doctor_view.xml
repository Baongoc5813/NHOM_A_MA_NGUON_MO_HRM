<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_doctor_list" model="ir.ui.view">
        <field name="name">hospital.doctor.list</field>
        <field name="model">hospital.doctor</field>
        <field name="arch" type="xml">
            <list string="Danh sách bác sĩ">
                <field name="name"/>
                <field name="phone"/>
                <field name="department"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_doctor_kanban" model="ir.ui.view">
        <field name="name">hospital.doctor.kanban</field>
        <field name="model">hospital.doctor</field>
        <field name="arch" type="xml">
            <kanban>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div>🏥 <field name="department"/></div>
                                <div>📞 <field name="phone"/></div>
                                <div class="mt-2">
                                    <field name="state" widget="label_selection" 
                                           options="{'classes': {'available': 'success', 'busy': 'danger', 'away': 'warning'}}"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_doctor_form" model="ir.ui.view">
        <field name="name">hospital.doctor.form</field>
        <field name="model">hospital.doctor</field>
        <field name="arch" type="xml">
            <form string="Thông tin bác sĩ">
                <header>
                    <field name="state" widget="statusbar" options="{'clickable': '1'}" statusbar_visible="available,busy,away"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Tên bác sĩ..."/></h1>
                    </div>
                    <notebook>
                        <page string="Thông tin cá nhân" name="personal_info">
                            <group>
                                <field name="phone"/>
                                <field name="birth_year"/>
                                <field name="age" invisible="birth_year == 0"/>
                            </group>
                        </page>
                        <page string="Chuyên môn" name="professional_expertise">
                            <group>
                                <field name="department"/>
                                <field name="email"/>
                                <field name="manager_id"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_doctor" model="ir.actions.act_window">
        <field name="name">Bác sĩ</field>
        <field name="res_model">hospital.doctor</field>
        <field name="view_mode">kanban,list,form</field>
    </record>
</odoo>