<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_calendar_event_interview_form" model="ir.ui.view">
        <field name="name">calendar.event.interview.form</field>
        <field name="model">calendar.event</field>
        <field name="inherit_id" ref="calendar.view_calendar_event_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='description']" position="after">
                <group string="Interview Info" invisible="not is_interview">
                    <group>
                        <field name="is_interview" invisible="1"/>
                        <field name="applicant_id"
                               groups="interview_scheduling.group_hr_interview_officer"/>
                        <field name="interview_round"/>
                        <field name="interview_type"/>
                        <field name="interview_meeting_url"
                               invisible="interview_type != 'online'"/>
                    </group>
                    <group>
                        <field name="candidate_attendance"
                               groups="interview_scheduling.group_hr_interview_officer"/>
                        <field name="interview_feedback_count" readonly="1"/>
                    </group>
                </group>
                <div invisible="not is_interview"
                     groups="interview_scheduling.group_hr_interview_officer">
                    <button name="action_send_interview_invitations"
                            string="Send Invitations"
                            type="object"
                            class="btn btn-primary"/>
                    <button name="action_open_interview_feedbacks"
                            string="View Feedbacks"
                            type="object"
                            class="btn btn-secondary"
                            invisible="interview_feedback_count == 0"/>
                </div>
                <div invisible="not is_interview"
                     groups="interview_scheduling.group_hr_interview_officer">
                    <button name="action_mark_showed_up"
                            string="Showed Up"
                            type="object"
                            class="btn btn-success btn-sm"/>
                    <button name="action_mark_no_show"
                            string="No Show"
                            type="object"
                            class="btn btn-danger btn-sm"/>
                    <button name="action_mark_rescheduled"
                            string="Rescheduled"
                            type="object"
                            class="btn btn-warning btn-sm"/>
                </div>
            </xpath>
        </field>
    </record>

    <record id="view_calendar_event_interview_list" model="ir.ui.view">
        <field name="name">calendar.event.interview.list</field>
        <field name="model">calendar.event</field>
        <field name="arch" type="xml">
            <list decoration-success="candidate_attendance == 'showed_up'"
                  decoration-danger="candidate_attendance == 'no_show'"
                  decoration-warning="candidate_attendance == 'rescheduled'">
                <field name="name"/>
                <field name="applicant_id"/>
                <field name="interview_round"/>
                <field name="interview_type" widget="badge"/>
                <field name="start"/>
                <field name="stop"/>
                <field name="candidate_attendance" widget="badge"
                       decoration-success="candidate_attendance == 'showed_up'"
                       decoration-danger="candidate_attendance == 'no_show'"
                       decoration-warning="candidate_attendance == 'rescheduled'"/>
                <field name="interview_feedback_count"/>
            </list>
        </field>
    </record>

    <record id="action_interview_events" model="ir.actions.act_window">
        <field name="name">Interview Schedule</field>
        <field name="res_model">calendar.event</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_interview', '=', True)]</field>
        <field name="context">{'default_is_interview': True}</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_calendar_event_interview_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_calendar_event_interview_form')}),
        ]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No interviews scheduled yet</p>
        </field>
    </record>

</odoo>
