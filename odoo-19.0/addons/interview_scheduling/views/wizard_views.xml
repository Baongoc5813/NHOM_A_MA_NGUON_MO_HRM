<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_interview_schedule_wizard_form" model="ir.ui.view">
        <field name="name">interview.schedule.wizard.form</field>
        <field name="model">interview.schedule.wizard</field>
        <field name="arch" type="xml">
            <form string="Schedule Interview">
                <sheet>
                    <group string="Candidate">
                        <group>
                            <field name="candidate_name" readonly="1"/>
                            <field name="job_id" readonly="1"/>
                            <field name="interview_round"/>
                            <field name="interview_type"/>
                        </group>
                        <group>
                            <field name="meeting_url"
                                   invisible="interview_type != 'online'"/>
                            <field name="location"
                                   invisible="interview_type == 'online'"/>
                            <field name="duration"/>
                            <field name="interviewer_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <group string="Search Window">
                        <group>
                            <field name="date_from"/>
                        </group>
                        <group>
                            <field name="date_to"/>
                        </group>
                    </group>
                    <group string="Selected Slot" invisible="not selected_start">
                        <field name="selected_start" readonly="1"/>
                        <field name="selected_stop" readonly="1"/>
                    </group>
                    <separator string="Available Slots"
                               invisible="available_slot_ids == []"/>
                    <field name="available_slot_ids" nolabel="1"
                           invisible="available_slot_ids == []">
                        <list>
                            <field name="label" string="Time Slot"/>
                            <field name="start"/>
                            <field name="stop"/>
                            <button name="action_select_slot"
                                    string="Select"
                                    type="object"
                                    class="btn btn-sm btn-primary"/>
                        </list>
                    </field>
                </sheet>
                <footer>
                    <button name="action_find_slots"
                            string="Find Available Slots"
                            type="object"
                            class="btn-primary"/>
                    <button name="action_confirm_schedule"
                            string="Confirm and Schedule"
                            type="object"
                            class="btn-primary"
                            invisible="not selected_start"/>
                    <button string="Cancel" special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
