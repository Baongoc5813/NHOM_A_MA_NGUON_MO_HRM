<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_error" name="Portal Error">
        <t t-call="website.layout">
            <div class="container mt-5 text-center">
                <h3><t t-esc="msg"/></h3>
                <p>Vui lòng liên hệ HR để được hỗ trợ.</p>
            </div>
        </t>
    </template>

    <template id="portal_status" name="Portal Status">
        <t t-call="website.layout">
            <div class="container mt-5">
                <h3>Xin chào, <t t-esc="applicant.partner_name"/></h3>
                <p>Vị trí ứng tuyển: <strong><t t-esc="applicant.job_id.name"/></strong></p>

                <div class="mt-4">
                    <h5>Tiến độ hồ sơ</h5>
                    <style>
                        .candidate-steps { display:flex; justify-content:space-between; list-style:none; padding:0; margin:20px 0; }
                        .candidate-steps li { flex:1; position:relative; text-align:center; }
                        .candidate-steps li:not(:last-child)::after { content:''; position:absolute; top:18px; right:-50%; height:4px; background:#e9ecef; width:100%; z-index:0; }
                        .candidate-steps li.completed::after { background:#28a745; }
                        .candidate-steps li .step { display:inline-block; width:36px; height:36px; line-height:36px; border-radius:50%; background:#e9ecef; z-index:1; position:relative; }
                        .candidate-steps li.completed .step { background:#28a745; color:white; }
                        .candidate-steps li.current .step { background:#007bff; color:white; }
                        .candidate-steps li .label { margin-top:8px; display:block; font-size:14px; }
                    </style>

                    <ul class="candidate-steps">
                        <t t-foreach="stages" t-as="stage">
                            <t t-set="pos" t-value="positions.get(stage.id)"/>
                            <li t-att-class="'completed' if pos &lt; current_index else ('current' if pos == current_index else '')">
                                <span class="step"><t t-esc="pos + 1"/></span>
                                <span class="label"><t t-esc="stage.name"/></span>
                            </li>
                        </t>
                    </ul>
                    <p class="mt-3">Trạng thái hiện tại: <strong><t t-esc="applicant.stage_id.name"/></strong></p>
                </div>
            </div>
        </t>
    </template>
</odoo>
