<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_library_book_list" model="ir.ui.view">
            <field name="name">library.book.list</field>
            <field name="model">library.book</field> <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="author"/>
                    <field name="quantity"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="view_library_book_form" model="ir.ui.view">
            <field name="name">library.book.form</field>
            <field name="model">library.book</field> <field name="arch" type="xml">
                <form>
                    <sheet>
                        <field name="image" widget="image" class="oe_avatar"/>
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Tên sách..."/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="author"/>
                                <field name="isbn"/>
                            </group>
                            <group>
                                <field name="quantity"/>
                                <field name="state"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Mô tả">
                                <field name="description"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_library_book" model="ir.actions.act_window">
            <field name="name">Quản lý Sách</field>
            <field name="res_model">library.book</field> <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_library_root" name="Library Portal" sequence="10"/>
        <menuitem id="menu_library_book" name="Danh sách sách" parent="menu_library_root" action="action_library_book"/>
    </data>
</odoo>