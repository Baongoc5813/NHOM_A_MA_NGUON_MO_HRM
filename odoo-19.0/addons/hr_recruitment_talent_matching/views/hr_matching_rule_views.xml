<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_matching_rule_form_clean" model="ir.ui.view">
        <field name="name">hr.matching.rule.form.clean</field>
        <field name="model">hr.matching.rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="rule_type"/>
                        </group>
                        <group>
                            <field name="weight"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="tag_ids" widget="many2many_tags" string="Required skills"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hr_matching_rule_list_clean" model="ir.ui.view">
        <field name="name">hr.matching.rule.list.clean</field>
        <field name="model">hr.matching.rule</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="rule_type"/>
                <field name="weight"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_hr_matching_rule_clean" model="ir.actions.act_window">
        <field name="name">Matching Rules</field>
        <field name="res_model">hr.matching.rule</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_talent_matching_root" name="Talent Matching" sequence="100"/>
    <menuitem id="menu_hr_matching_rule_config" name="Matching Rules" parent="menu_talent_matching_root" action="action_hr_matching_rule_clean" sequence="10"/>
</odoo>